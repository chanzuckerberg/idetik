{
  "name": "viz",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "main": "src/index.ts",
  "scripts": {
    "dev": "vite",
    "compile": "tsc",
    "build": "tsc && vite build",
    "test": "vitest",
    "test-with-coverage": "vitest run --coverage",
    "format": "prettier --write './**/*.{ts,html,json}'",
    "format-check": "prettier --check './**/*.{ts,html,json}'",
    "lint": "eslint ."
  },
  "dependencies": {
    "gl-matrix": "^3.4.3",
    "zarrita": "^0.4.0-next.16"
  },
  "devDependencies": {
    "@eslint/js": "^9.9.0",
    "@types/gl-matrix": "^3.2.0",
    "@types/webgl2": "^0.0.11",
    "@typescript-eslint/eslint-plugin": "^8.1.0",
    "@typescript-eslint/parser": "^8.1.0",
    "@vitest/browser": "^2.0.5",
    "@vitest/coverage-istanbul": "^2.0.5",
    "eslint": "^9.9.0",
    "globals": "^15.9.0",
    "husky": "^9.1.4",
    "jsdom": "^24.1.1",
    "playwright": "^1.46.1",
    "prettier": "^3.3.2",
    "typescript": "^5.2.2",
    "typescript-eslint": "^8.1.0",
    "vite": "^5.4.6",
    "vite-plugin-eslint": "^1.8.1",
    "vite-plugin-glsl": "^1.3.0",
    "vite-tsconfig-paths": "^4.3.2",
    "vitest": "^2.0.5"
  },
  "husky": {
    "hooks": {
      "pre-commit": "npm run format"
    }
  }
}
