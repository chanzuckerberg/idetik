{
  "name": "@idetik/react",
  "private": true,
  "version": "0.0.1",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "compile": "tsc",
    "build": "vite build && tsc && rollup -c rollup.config.js",
    "format": "prettier --write './**/*.{ts,tsx,html,json}'",
    "format-check": "prettier --check './**/*.{ts,tsx,html,json}'",
    "lint": "eslint ."
  },
  "dependencies": {
    "@czi-sds/components": "^22.1.2",
    "@emotion/css": "^11.13.0",
    "@emotion/react": "^11.13.3",
    "@emotion/styled": "^11.13.0",
    "@eslint/js": "^9.9.0",
    "@idetik/core": "^0.0.1",
    "@mui/base": "^5.0.0-beta.58",
    "@mui/icons-material": "^5.16.7",
    "@mui/lab": "^5.0.0-alpha.173",
    "@mui/material": "^5.16.7",
    "@types/react-dom": "^18.3.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "description": "idetik react components",
  "main": "./dist/index.umd.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "style": "./dist/style.css",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.umd.cjs"
    },
    "./style.css": "./dist/style.css",
    "./dist/*.js.map": "./dist/*.js.map",
    "./dist/*.cjs.map": "./dist/*.cjs.map",
    "./dist/*.d.ts.map": "./dist/*.d.ts.map"
  },
  "files": [
    "dist"
  ],
  "author": "",
  "license": "ISC",
  "devDependencies": {
    "@types/classnames": "^2.3.0",
    "autoprefixer": "^10.4.20",
    "classnames": "^2.5.1",
    "tailwindcss": "^3.4.17"
  },
  "peerDependencies": {
    "@czi-sds/components": "^22.1.2",
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  }
}
