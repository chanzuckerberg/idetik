{
  "name": "@idetik/react",
  "private": true,
  "version": "0.0.1",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "compile": "tsc",
    "build": "npm run build:css && tsc && vite build",
    "format": "prettier --write './**/*.{ts,tsx,html,json}'",
    "format-check": "prettier --check './**/*.{ts,tsx,html,json}'",
    "lint": "eslint .",
    "build:css": "mkdir -p dist && npx tailwindcss -i ./src/index.css -o ./dist/index.css --minify"
  },
  "dependencies": {
    "@czi-sds/components": "^22.1.2",
    "@emotion/css": "^11.13.0",
    "@emotion/react": "^11.13.3",
    "@emotion/styled": "^11.13.0",
    "@eslint/js": "^9.9.0",
    "@idetik/core": "^0.0.1",
    "@mui/base": "^5.0.0-beta.58",
    "@mui/icons-material": "^5.16.7",
    "@mui/lab": "^5.0.0-alpha.173",
    "@mui/material": "^5.16.7",
    "@tailwindcss/vite": "^4.0.8",
    "@types/react-dom": "^18.3.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "description": "idetik react components",
  "author": "",
  "license": "ISC",
  "devDependencies": {
    "@tailwindcss/nesting": "^0.0.0-insiders.565cd3e",
    "@tailwindcss/typography": "^0.5.16",
    "@types/classnames": "^2.3.0",
    "autoprefixer": "^10.4.20",
    "classnames": "^2.5.1",
    "postcss": "^8.5.3",
    "tailwindcss": "^3.4.17"
  },
  "main": "dist/index.js",
  "module": "dist/index.mjs",
  "style": "dist/index.css",
  "files": [
    "dist",
    "src/index.css"
  ],
  "peerDependencies": {
    "@czi-sds/components": "^22.1.2",
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  }
}
