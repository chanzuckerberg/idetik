{
  "name": "@idetik/core-prerelease",
  "version": "2.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "compile": "tsc",
    "build": "vite build && tsc && rollup -c rollup.config.js",
    "build:examples": "node generate-examples-manifest.js && cp examples/examples-manifest.json public/ && vite build --mode examples",
    "test": "vitest",
    "test-with-coverage": "vitest run --coverage",
    "format": "prettier --write './**/*.{ts,tsx,html,json}'",
    "format-check": "prettier --check './**/*.{ts,tsx,html,json}'",
    "lint": "eslint .",
    "pub": "npm run build; npm publish --access=public"
  },
  "dependencies": {
    "gl-matrix": "^3.4.3",
    "zarrita": "^0.4.0-next.16",
    "zod": "^3.24.1"
  },
  "description": "A layer-based visualization abstraction",
  "main": "./dist/index.umd.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.umd.cjs"
    },
    "./dist/*.js.map": "./dist/*.js.map",
    "./dist/*.cjs.map": "./dist/*.cjs.map",
    "./dist/*.d.ts.map": "./dist/*.d.ts.map"
  },
  "files": [
    "dist"
  ],
  "directories": {
    "test": "test"
  },
  "author": "",
  "license": "MIT",
  "keywords": [
    "idetik"
  ],
  "devDependencies": {
    "@apidevtools/json-schema-ref-parser": "^14.1.1",
    "json-schema-to-zod": "^2.6.1"
  }
}
